# Required now: Auth0 app session foundation.
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
AUTH0_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# Recommended now: shell copy and Google connected-account naming.
NEXT_PUBLIC_APP_NAME=Warrant
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH0_GOOGLE_CONNECTION_NAME=google-oauth2

# Optional later: downstream API audiences and Token Vault/connected-account identifiers.
AUTH0_AUDIENCE=YOUR_AUTH0_AUDIENCE
AUTH0_TOKEN_VAULT_CONNECTION_ID=YOUR_TOKEN_VAULT_CONNECTION_ID

# Optional debug-only shell overrides. Leave blank in normal local setup.
WARRANT_GOOGLE_CONNECTION_STATE=
WARRANT_GOOGLE_CONNECTION_EMAIL=

# Configure Google OAuth client credentials in the Auth0 dashboard's Google connection.
# Do not add Google client secrets to the Next.js app env for this branch.

# Runtime model adapter (Gemma). Keep real keys in .env.local only.
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
WARRANT_RUNTIME_MODEL_PROVIDER_ID=gemma-4-31b
WARRANT_RUNTIME_MODEL_TEMPERATURE=0.1
WARRANT_RUNTIME_MODEL_TOP_P=0.1
WARRANT_RUNTIME_MODEL_MAX_OUTPUT_TOKENS=2048

# Later tracks only.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
DATABASE_URL=YOUR_DATABASE_URL
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
