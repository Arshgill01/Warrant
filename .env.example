# Required: server-side app/auth wiring
APP_BASE_URL=https://your-app.vercel.app
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_SECRET=replace_with_64_hex_chars

# Optional Auth0 values
AUTH0_AUDIENCE=https://your-api-audience
AUTH0_GOOGLE_CONNECTION_NAME=google-oauth2
AUTH0_TOKEN_VAULT_CONNECTION_ID=con_xxxxxxxxxxxxx

# Required for runtime model invocation and live preflight runtime checks
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
WARRANT_RUNTIME_MODEL_PROVIDER_ID=gemma-4-31b-it
WARRANT_RUNTIME_MODEL_TEMPERATURE=0.1
WARRANT_RUNTIME_MODEL_TOP_P=0.1
WARRANT_RUNTIME_MODEL_MAX_OUTPUT_TOKENS=2048

# Demo-only local overrides (leave blank unless intentionally testing override behavior)
WARRANT_GOOGLE_CONNECTION_STATE=
WARRANT_GOOGLE_CONNECTION_EMAIL=
WARRANT_ENABLE_DEMO_TOOLS=false
WARRANT_DEMO_STATE_FILE=/tmp/warrant-demo-state.json

# Optional local smoke/preflight script overrides
SMOKE_PORT=3107
LIVE_PREFLIGHT_BASE_URL=http://127.0.0.1:3000
LIVE_PREFLIGHT_MODE=token-only
LIVE_PREFLIGHT_COOKIE=appSession=replace_with_session_cookie
